<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Cliente - Barbearia Digital</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        form {
            background: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
            width: 100%;
            max-width: 420px;
            border-top: 4px solid #1a1a2e;
        }

        h1 {
            color: #1a1a2e;
            text-align: center;
            margin-bottom: 30px;
            font-size: 26px;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: #333;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 16px;
            transition: all 0.3s ease;
            background: #f5f5f5;
        }

        input:focus {
            outline: none;
            border-color: #1a1a2e;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26, 26, 46, 0.1);
        }

        button {
            width: 100%;
            padding: 16px;
            background: #1a1a2e;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        button:hover {
            background: #16213e;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(26, 26, 46, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        .message {
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            display: none;
        }

        .message.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            display: block;
        }

        .message.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            display: block;
        }

        .user-id {
            background: #f5f5f5;
            padding: 10px 15px;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 20px;
            color: #666;
            font-size: 14px;
            border: 1px solid #e0e0e0;
        }

        .error-container {
            background: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
            width: 100%;
            max-width: 420px;
            text-align: center;
            border-top: 4px solid #dc3545;
        }

        .error-container h1 {
            color: #dc3545;
            margin-bottom: 15px;
        }

        .error-container p {
            color: #666;
        }
    </style>
</head>
<body>
    
    <% if(usuario) { %>
    <form id="formEdit">
        <h1>Editar Cliente</h1>

        <div id="message" class="message"></div>

        <div class="user-id">
            ID do Cliente: <strong><%= usuario.id %></strong>
        </div>

        <input value="<%= usuario.id %>" type="text" id="usuarioId" hidden>

        <div class="form-group">
            <label for="username">Nome</label>
            <input value="<%= usuario.nome %>" type="text" id="username" placeholder="Digite o nome" required>
        </div>
        <div class="form-group">
            <label for="email">E-mail</label>
            <input value="<%= usuario.email %>" type="email" id="email" placeholder="Digite o e-mail" required>
        </div>
        <div class="form-group">
            <label for="senha">Nova Senha</label>
            <input type="password" id="senha" placeholder="Digite a nova senha">
        </div>
        <div>
            <button id="btnAtualizarUsuario" type="submit">Atualizar</button>
        </div>
    </form>
    <% } else { %>
    <div class="error-container">
        <h1>Cliente não encontrado</h1>
        <p>O cliente solicitado não existe no sistema.</p>
    </div>
    <% } %>

</body>
<script>
<% if(usuario) { %>
    const btnAtualizarUsuario = document.getElementById("btnAtualizarUsuario")
    const messageDiv = document.getElementById("message")
  
    btnAtualizarUsuario.addEventListener("click", atualizarUsuario)

    function showMessage(text, type) {
        messageDiv.textContent = text
        messageDiv.className = 'message ' + type
        setTimeout(() => {
            messageDiv.className = 'message'
        }, 3000)
    }

    async function atualizarUsuario(e)
    {
        e.preventDefault()

        const id = document.getElementById("usuarioId")
        const username = document.getElementById("username")
        const email = document.getElementById("email")
        const senha = document.getElementById("senha")
  
        const url = "/user/edit"

        try {
            const response = await fetch(url, { 
                method:'PUT',
                headers:{
                    'Content-Type':'application/json'
                },
                body: JSON.stringify(
                    {
                        id: id.value,
                        username : username.value,
                        email: email.value,
                        senha: senha.value
                    }
                )
            })

            const data = await response.json()

            if(!response.ok)
            {
                showMessage("Ocorreu um erro ao atualizar", "error")
                console.log("Ocorreu um erro na requisição")
                return
            }

            console.log(data)
            showMessage("Cliente atualizado com sucesso!", "success")
            
            // Limpar o campo de senha após atualização
            senha.value = ""

        } catch (error) {
            showMessage("Erro ao conectar com o servidor", "error")
            console.log(error)
        }
    }
<% } %>
</script>
</html>
