<!-- Atendimento/ListView -->

<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lista de Atendimentos</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Segoe UI', sans-serif;
    background:#0f172a;
    color:white;
    display:flex;
    min-height:100vh;
}

.sidebar{
    width:260px;
    background:#111827;
    padding:30px 20px;
    display:flex;
    flex-direction:column;
    gap:15px;
}

.sidebar h2{
    margin-bottom:20px;
}

.sidebar a{
    text-decoration:none;
    color:white;
    background:#1f2937;
    padding:14px;
    border-radius:10px;
}

.sidebar a:hover{
    background:#2563eb;
}

.content{
    flex:1;
    padding:40px;
}

.card{
    background:#111827;
    padding:30px;
    border-radius:16px;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:20px;
}

th, td{
    padding:16px;
    text-align:left;
}

thead{
    background:#1e293b;
}

tbody tr{
    border-bottom:1px solid #1f2937;
}

button{
    padding:10px 14px;
    border:none;
    border-radius:8px;
    background:#dc2626;
    color:white;
    cursor:pointer;
}

a{
    color:#60a5fa;
    text-decoration:none;
    margin-right:10px;
}

</style>

</head>

<body>

<div class="sidebar">
    <h2>Atendimentos</h2>

    <a href="/atendimento/list">Lista</a>
    <a href="/atendimento/create">Novo Atendimento</a>
</div>

<div class="content">

<div class="card">

<h1>Lista de Atendimentos</h1>

<table>

<thead>
<tr>
    <th>ID</th>
    <th>Cliente</th>
    <th>Telefone</th>
    <th>Serviço</th>
    <th>Profissional</th>
    <th>Ações</th>
</tr>
</thead>

<tbody>

<% for(atendimento of atendimentos) { %>

<tr>

<td><%= atendimento.id %></td>
<td><%= atendimento.nomeCLiente %></td>
<td><%= atendimento.telefone %></td>
<td><%= atendimento.tipoServico %></td>
<td><%= atendimento.profissional %></td>

<td>
    <a href="/atendimento/edit/<%= atendimento.id %>">
        Editar
    </a>

    <button onclick="apagarAtendimento('<%= atendimento.id %>')">
        Apagar
    </button>
</td>

</tr>

<% } %>

</tbody>

</table>

</div>

</div>

</body>
</html>